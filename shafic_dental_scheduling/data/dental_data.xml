<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Dental department (gives the 'dental' department_type a home;
             new appointments opened from the Dental Schedule default to
             it via the acs_department_type context). -->
        <record id="department_dental" model="hr.department">
            <field name="name">Dental</field>
            <field name="department_type">dental</field>
        </record>

        <!-- Starter chairs -->
        <record id="cabin_dental_chair_1" model="appointment.cabin">
            <field name="name">Dental Chair 1</field>
            <field name="sequence">1</field>
        </record>
        <record id="cabin_dental_chair_2" model="appointment.cabin">
            <field name="name">Dental Chair 2</field>
            <field name="sequence">2</field>
        </record>

        <!-- Starter visit types with default durations (hours) -->
        <record id="purpose_dental_checkup" model="appointment.purpose">
            <field name="name">Check-up / Consultation</field>
            <field name="default_duration">0.33</field>
        </record>
        <record id="purpose_dental_cleaning" model="appointment.purpose">
            <field name="name">Cleaning / Scaling</field>
            <field name="default_duration">0.5</field>
        </record>
        <record id="purpose_dental_filling" model="appointment.purpose">
            <field name="name">Filling</field>
            <field name="default_duration">0.5</field>
        </record>
        <record id="purpose_dental_extraction" model="appointment.purpose">
            <field name="name">Extraction</field>
            <field name="default_duration">0.75</field>
        </record>
        <record id="purpose_dental_rct" model="appointment.purpose">
            <field name="name">Root Canal (RCT)</field>
            <field name="default_duration">1.0</field>
        </record>

    </data>
</odoo>
