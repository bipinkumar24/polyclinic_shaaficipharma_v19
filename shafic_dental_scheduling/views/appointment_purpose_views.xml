<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_dental_purpose_list" model="ir.ui.view">
        <field name="name">dental.purpose.list</field>
        <field name="model">appointment.purpose</field>
        <field name="arch" type="xml">
            <list string="Visit Types" editable="bottom">
                <field name="name"/>
                <field name="default_duration"
                       string="Default Duration (hours)"/>
            </list>
        </field>
    </record>

    <record id="view_dental_purpose_form" model="ir.ui.view">
        <field name="name">dental.purpose.form</field>
        <field name="model">appointment.purpose</field>
        <field name="arch" type="xml">
            <form string="Visit Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="default_duration"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dental_purposes" model="ir.actions.act_window">
        <field name="name">Visit Types</field>
        <field name="res_model">appointment.purpose</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_dental_purpose_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_dental_purpose_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Define your visit types</p>
            <p>Give each a default duration so the appointment end time is
               set automatically when the visit type is chosen.</p>
        </field>
    </record>

</odoo>
