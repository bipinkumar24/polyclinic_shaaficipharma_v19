<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_dental_cabin_list" model="ir.ui.view">
        <field name="name">dental.cabin.list</field>
        <field name="model">appointment.cabin</field>
        <field name="arch" type="xml">
            <list string="Dental Chairs" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="notes"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_dental_cabin_form" model="ir.ui.view">
        <field name="name">dental.cabin.form</field>
        <field name="model">appointment.cabin</field>
        <field name="arch" type="xml">
            <form string="Dental Chair">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="notes"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dental_cabins" model="ir.actions.act_window">
        <field name="name">Dental Chairs</field>
        <field name="res_model">appointment.cabin</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_dental_cabin_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_dental_cabin_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your dental chairs</p>
            <p>Each chair is bookable on the Dental Schedule and protected
               from double-booking.</p>
        </field>
    </record>

</odoo>
