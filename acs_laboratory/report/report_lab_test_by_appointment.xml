<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Report Template -->
    <template id="report_lab_result_table_line_all">
        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else ''">
            <t t-if="not line.display_type">
                <td>
                    <span t-field="test.name"/>
                </td>
                <td>
                    <span t-field="test.test_id"/>
                </td>
                <td t-attf-class="text-#{line.result_type} #{'text-danger' if line.result_type in ['high','low'] else ''}">
                    <span t-field="line.name"/>
                </td>
                <td t-attf-class="text-#{line.result_type} #{'text-danger' if line.result_type in ['high','low'] else ''}">
                    <span t-field="line.result"/>
                </td>
                <td t-attf-class="text-#{line.result_type} #{'text-danger' if line.result_type in ['high','low'] else ''}">
                    <span t-field="line.normal_range"/>
                    <span t-if="line.lab_uom_id" t-field="line.lab_uom_id"/>
                </td>
                <td t-attf-class="text-#{line.result_type} #{'text-danger' if line.result_type in ['high','low'] else ''}">
                    <span t-field="line.remark"/>
                </td>
            </t>
            <t t-if="line.display_type == 'line_section'">
                <td colspan="6">
                    <strong>
                        <span t-field="line.name"/>
                    </strong>
                </td>
            </t>
        </tr>
    </template>
    <template id="report_lab_result_table_all">
        <table class="table table-sm o_main_table mt16">
            <thead>
                <tr>
                    <th>Investigation Number</th>
                    <th>Test</th>
                    <th>Test Name</th>
                    <th>Result</th>
                    <th>Normal Range</th>
                    <th>Remark</th>
                </tr>
            </thead>
            <tbody>

                <!-- Loop Tests -->
                <t t-foreach="lab_tests" t-as="test">

                    <!-- Reset tracker for each test -->
                    <t t-set="first_line" t-value="True"/>

                    <!-- Main Test Lines -->
                    <t t-foreach="test.critearea_ids" t-as="line">
                        <tr>

                            <!-- Show only first time -->
                            <t t-if="first_line">
                                <td>
                                    <strong><span t-field="test.name"/></strong>
                                </td>
                                <td>
                                    <strong><span t-field="test.test_id"/></strong>
                                </td>

                                <!-- Mark as used -->
                                <t t-set="first_line" t-value="False"/>
                            </t>
                            <t t-else="">
                                <td></td>
                                <td></td>
                            </t>

                            <!-- Always show -->
                            <td>
                                <span t-field="line.name"/>
                            </td>
                            <td t-attf-class="text-#{line.result_type} #{'text-danger' if line.result_type in ['high','low'] else ''}">
                                <span t-field="line.result"/>
                            </td>
                            <td>
                                <span t-field="line.normal_range"/>
                                <span t-if="line.lab_uom_id" t-field="line.lab_uom_id"/>
                            </td>
                            <td>
                                <span t-field="line.remark"/>
                            </td>
                        </tr>
                    </t>

                    <!-- Child Tests -->
                    <t t-if="test.child_test_ids">
                        <t t-foreach="test.child_test_ids" t-as="child">

                            <!-- Reset again for child -->
                            <t t-set="first_line" t-value="True"/>

                            <t t-foreach="child.critearea_ids" t-as="line">
                                <tr>

                                    <!-- Show only first time -->
                                    <t t-if="first_line">
                                        <td>
                                            <strong><span t-field="child.name"/></strong>
                                        </td>
                                        <td>
                                            <strong><span t-field="child.test_id"/></strong>
                                        </td>

                                        <t t-set="first_line" t-value="False"/>
                                    </t>
                                    <t t-else="">
                                        <td></td>
                                        <td></td>
                                    </t>

                                    <!-- Always show -->
                                    <td>
                                        <span t-field="line.name"/>
                                    </td>
                                    <td t-attf-class="text-#{line.result_type} #{'text-danger' if line.result_type in ['high','low'] else ''}">
                                        <span t-field="line.result"/>
                                    </td>
                                    <td>
                                        <span t-field="line.normal_range"/>
                                        <span t-if="line.lab_uom_id" t-field="line.lab_uom_id"/>
                                    </td>
                                    <td>
                                        <span t-field="line.remark"/>
                                    </td>
                                </tr>
                            </t>

                        </t>
                    </t>

                </t>

            </tbody>
        </table>
    </template>
