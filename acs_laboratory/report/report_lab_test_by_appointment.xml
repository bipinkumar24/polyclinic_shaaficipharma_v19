    <template id="report_acs_lab_test_all">
        <t t-call="web.html_container">
            <t t-foreach="grouped_docs" t-as="group">
                <t t-call="web.external_layout">
                    <style>
                        .lab-report-font {
                            font-size: 18px;
                        }
                        .lab-report-font table th,
                        .lab-report-font table td,
                        .lab-report-font table td span,
                        .lab-report-font table td div {
                            font-size: 18px !important;
                        }
                    </style>

                    <div class="page lab-report-font">

                        <!-- First Record -->
                        <t t-set="doc" t-value="group['tests'][0]"/>

                        <h2 class="text-center">
                            Investigation
                        </h2>

                        <div class="mt8 mb8" id="informations">
                            <div class="row">
                                <div t-if="doc.patient_id" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Patient:</strong>
                                    <p class="m-0" t-field="doc.patient_id"/>
                                </div>
                                <div t-if="doc.request_id.patient_age" class="col-3 mb-2">
                                    <strong>Patient Age</strong>
                                    <p class="m-0" t-field="doc.request_id.patient_age"/>
                                </div>
                                <div t-if="doc.patient_id.gender" class="col-3 mb-2">
                                    <strong>Gender</strong>
                                    <p class="m-0" t-field="doc.patient_id.gender"/>
                                </div>
                                <div t-if="doc.date_analysis" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Date:</strong>
                                    <p class="m-0" t-field="doc.date_analysis"/>
                                </div>
                            </div>
                            <div class="row">
                                <div t-if="doc.appointment_id" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Appointment:</strong>
                                    <p class="m-0" t-field="doc.appointment_id"/>
                                </div>
                            </div>
                        </div>
                        <t t-call="acs_laboratory.report_lab_result_table_all">
                            <t t-set="lab_tests" t-value="group['tests']"/>        
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_acs_lab_test_mutiple" model="ir.actions.report">
        <field name="name">Lab Report Appoinmnet Wise</field>
        <field name="model">patient.laboratory.test</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">acs_laboratory.report_acs_lab_test_all</field>
        <field name="report_file">acs_laboratory.report_acs_lab_test_all</field>
        <field name="print_report_name">(object.name or 'LabReport').replace('/','_') + '_LabReport'</field>
        <field name="binding_model_id" ref="model_patient_laboratory_test"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
