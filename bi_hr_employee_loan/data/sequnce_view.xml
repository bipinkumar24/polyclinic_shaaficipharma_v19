<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
	    <record id="seq_employee_loan" model="ir.sequence">
	        <field name="name">Seq</field>
	        <field name="code">loan.request</field>
	        <field name="prefix">LOAN</field>
	        <field name="padding">5</field>
	        <field name="company_id" eval="False"/>
	    </record>
	</data>
	 <record id="hr_salary_rule_loan" model="hr.salary.rule">
        <field name="category_id" ref="hr_payroll.DED"/>
        <field name="name">Loan</field>
        <field name="code">INSTALLMENT</field>
        <field name="sequence">7</field>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -employee.get_installment_loan(employee.id,payslip.date_from,payslip.date_to)</field>
        <field name="struct_id" ref="hr_payroll.structure_002"/>
    </record>
</odoo>
