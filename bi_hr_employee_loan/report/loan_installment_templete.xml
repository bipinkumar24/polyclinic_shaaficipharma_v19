<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="loan_installment_templete">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="text-center">
                            <h4 style="font-weight:600;">Loan Installments Details</h4>
                        </div>
                        <div class="text-center">
                            <h6 style="font-weight:600;">Date from <span t-esc="docs.date_from"/> To <span t-esc="docs.date_to"/></h6>
                        </div>
                        <br/>
                        <t t-foreach="data" t-as="employee">
                            <div class="text-center">
                                <h4 style="font-weight:600;"><span t-esc="employee.get('employee_id').name"/></h4>
                            </div>
                            <table class="table table-bordered mt32" style="font-size: 12px;">
                                <tr>
                                    <th>Loan</th>
                                    <th>Principal Amount</th>
                                    <th>Interest Amount</th>
                                    <th>EMI(Installment)</th>
                                    <th>Balance</th>
                                    <th>State</th>
                                </tr>
                                <tbody>
                                    <t t-foreach="employee.get('lines')" t-as="line">
                                        <tr>
                                            <td class="text-left"> 
                                                 <span t-esc="line.loan_id.name"/>
                                            </td>
                                            <td class="text-left"> 
                                                 <span t-esc="line.principal_amount"/>
                                            </td>
                                            <td class="text-left"> 
                                                 <span t-esc="line.interest_amount"/>
                                            </td>
                                            <td class="text-left"> 
                                                 <span t-esc="line.emi_installment"/>
                                            </td>
                                            <td class="text-left"> 
                                                 <span t-esc="line.loan_amount_balance"/>
                                            </td>
                                            <td class="text-left"> 
                                                 <span t-esc="line.state"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr>
                                        <th class="text-center">Total</th>
                                        <th ><span  t-esc="sum(employee.get('lines').mapped('principal_amount'))" t-options='{"widget": "float", "precision": 2}'/></th>
                                        <th><span  t-esc="sum(employee.get('lines').mapped('interest_amount'))" t-options='{"widget": "float", "precision": 2}'/></th>
                                        <th ><span  t-esc="sum(employee.get('lines').mapped('emi_installment'))" t-options='{"widget": "float", "precision": 2}'/></th>
                                        <th ><span  t-esc="sum(employee.get('lines').mapped('loan_amount_balance'))" t-options='{"widget": "float", "precision": 2}'/></th>
                                        <th ></th>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
