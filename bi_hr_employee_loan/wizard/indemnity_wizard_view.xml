<?xml version="1.0"  encoding="utf-8"?>
<odoo>
    <record id="indemnity_wizard_wizard_FORM" model="ir.ui.view">
	   	<field name="name">indemnity.wizard.wizard.form</field>
	   	<field name="model">indemnity.wizard</field>
	   	<field name="priority">2</field>
	   	<field name="arch" type="xml">
		   	<form>
	            <sheet>
	                <group>
	                    <group>
	                        <field name="date_from" required="1"/>
	                    </group>
	                    <group>
	                        <field name="date_to" required="1"/>
	                    </group>
	                </group>
	                <group>
	                	<field name="employee_ids" widget="many2many_tags"/>
	                </group>
	            </sheet>
	            <footer>
	            	<button string="View" name="button_generate_partner_ladger" type="object" class="btn-primary"/>
	                <!-- <button string="Generate Report" name="button_generate_report" type="object" class="btn-primary"/> -->
	                <button string="Cancel" class="btn-secondary" special="cancel" />
	            </footer>
	        </form>
		</field>
	</record>
	<record id="action_indemnity_wizard" model="ir.actions.act_window">
        <field name="name">Indemnity Report</field>
        <field name="res_model">indemnity.wizard</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
	<menuitem  id="indemnity_wizard_wizard" parent="hr_payroll.menu_hr_payroll_report" name="Indemnity Report" sequence="100" action="action_indemnity_wizard" groups="bi_hr_employee_loan.action_show_report_admin_id"/>
</odoo>
