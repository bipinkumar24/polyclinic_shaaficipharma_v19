<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="plpl_res_config_settings_form_inherit">
        <field name="name">plpl.res.config.settings.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_inventory_section']/setting[last()]" position="after">
                <setting
                    title="Stock Locations"
                    string="Stock Locations"
                    help="Select the stock location(s) whose products will be loaded into POS."
                >
                    <field
                        name="stock_location_ids"
                        widget="many2many_tags"
                        domain="[('usage', '=', 'internal'), ('company_id', '=', company_id)]"
                    />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>