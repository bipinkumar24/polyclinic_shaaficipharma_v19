<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hms_appointment_form_card_commission" model="ir.ui.view">
        <field name="name">hms.appointment.form.card.commission</field>
        <field name="model">hms.appointment</field>
        <field name="inherit_id" ref="acs_hms.view_hms_appointment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_charge_the_appoinmnet_fee']" position="after">
                <field name="card_commission_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
