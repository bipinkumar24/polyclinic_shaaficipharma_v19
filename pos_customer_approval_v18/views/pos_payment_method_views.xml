<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Payment Method form: Credit Limit field ───────────────────── -->
    <record id="view_pos_payment_method_form_credit_limit" model="ir.ui.view">
        <field name="name">pos.payment.method.form.credit.limit</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <field name="split_transactions" position="after">
                <field name="check_credit_limit"
                       widget="boolean_toggle"
                       string="Check Customer Credit Limit"
                       help="When enabled, POS will prevent validation if the selected customer's order total exceeds their configured POS Credit Limit."/>
            </field>
        </field>
    </record>

    <!-- ── Payment Method list: show check_credit_limit column ──────── -->
    <record id="view_pos_payment_method_tree_credit_limit" model="ir.ui.view">
        <field name="name">pos.payment.method.list.credit.limit</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_tree"/>
        <field name="arch" type="xml">
            <field name="split_transactions" position="after">
                <field name="check_credit_limit"
                       optional="show"
                       string="Credit Limit Check"/>
            </field>
        </field>
    </record>

</odoo>
