<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="stock_view_picking_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <field name="internal_journal_entries_ids" invisible="1"/>
                <button name="action_view_journal_entry" string="Journal Entry" type="object" class="oe_stat_button" icon="fa-list" invisible ="internal_journal_entries_ids"/>
            </xpath>
        </field>
    </record>

    <record id="view_warehouse_tree_picking_data" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="branch_id"/>
            </field>
        </field>
    </record>

    <record id="view_stock_quant_tree_editable_stock_quant" model="ir.ui.view">
        <field name="name">stock.quant.tree.editable.inherit.expiry_date</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="branch_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_quant_tree_editable_stock_quant" model="ir.ui.view">
        <field name="name">stock.quant.tree.editable.inherit.expiry_date</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="branch_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_account_move_line" model="ir.ui.view">
        <field name="name">account.move.line.tree.inherit.expiry_date</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="before">
                <field name="location_id"/>
            </xpath>
        </field>
    </record>

    <!--
        Odoo 19 removed the `stock.valuation.layer` model and its list view
        (`stock_account.stock_valuation_layer_tree`). The inherited view that
        added a `branch_id` column to that list has been removed accordingly.
    -->

    </data>
</odoo>
