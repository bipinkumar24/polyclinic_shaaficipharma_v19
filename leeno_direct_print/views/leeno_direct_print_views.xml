<odoo>

    <!-- ══════════════════════════════════════════════════════════════
         Direct Print Wizard – form view
         ══════════════════════════════════════════════════════════════ -->
    <record id="view_leeno_direct_print_wizard_form" model="ir.ui.view">
        <field name="name">leeno.direct.print.wizard.form</field>
        <field name="model">odoo.leeno.direct.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Direct Print">
                <group>
                    <field name="model" invisible="1"/>
                    <field name="report_ref" invisible="1"/>
                    <field name="res_ids" invisible="1"/>
                    <field name="report_id" options="{'no_create': True}"/>
                    <field name="record_count" string="Records selected"/>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>How it works:</strong> Click <em>Print</em> and your
                    browser's native print dialog will open so you can choose any
                    printer connected to your computer (USB, network, or virtual).
                </div>
                <footer>
                    <button string="Print" type="object" name="action_print"
                            class="btn-primary" icon="fa-print"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_leeno_direct_print_wizard" model="ir.actions.act_window">
        <field name="name">Direct Print</field>
        <field name="res_model">odoo.leeno.direct.print.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_leeno_direct_print_wizard_form"/>
        <field name="target">new</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Add "Use Direct Print" toggle on report configuration
         ══════════════════════════════════════════════════════════════ -->
    <record id="view_ir_actions_report_form_leeno_direct_print" model="ir.ui.view">
        <field name="name">ir.actions.report.form.leeno_direct_print</field>
        <field name="model">ir.actions.report</field>
        <field name="inherit_id" ref="base.act_report_xml_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='print_report_name']" position="after">
                <field name="use_leeno_direct_print"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Configuration menu
         ══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_leeno_direct_print_root"
              name="Direct Print"
              sequence="90"/>
    <menuitem id="menu_leeno_direct_print_config"
              name="Configuration"
              parent="menu_leeno_direct_print_root"
              sequence="10"/>

    <record id="action_create_print_actions" model="ir.actions.server">
        <field name="name">Create / Repair Print Actions</field>
        <field name="model_id" ref="model_odoo_leeno_direct_print_action"/>
        <field name="state">code</field>
        <field name="code">
action = env['odoo.leeno.direct.print.action'].action_create_print_actions()
        </field>
    </record>

    <menuitem id="menu_create_print_actions"
              name="Create / Repair Print Actions"
              parent="menu_leeno_direct_print_config"
              action="action_create_print_actions"/>

    <!-- ══════════════════════════════════════════════════════════════
         Binding actions – gear menu entries
         ══════════════════════════════════════════════════════════════ -->
    <record id="action_leeno_direct_print_partner" model="ir.actions.server">
        <field name="name">Direct Print</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = {
        'name': 'Direct Print',
        'type': 'ir.actions.act_window',
        'res_model': 'odoo.leeno.direct.print.wizard',
        'view_mode': 'form',
        'target': 'new',
        'context': {
            'default_model': records._name,
            'active_model': records._name,
            'active_ids': records.ids,
            'active_id': records.ids[0] if records.ids else False,
        },
    }
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Header buttons on document forms
         ══════════════════════════════════════════════════════════════ -->

