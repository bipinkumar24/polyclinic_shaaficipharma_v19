<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_inherit_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='companies']" position="inside">
                 <block title="Commission Accounts" name="commission_setting_container">
                    <setting help="Default Debit Accounts" id="commission_debit_account_id">
                        <field name="commission_debit_account_id" class="o_light_label"/>
                    </setting>
                    <setting string="Default Credit Accounts" help="Create commission based on invoice amount by default" id="commission_credit_account_id">
                        <field name="commission_credit_account_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
