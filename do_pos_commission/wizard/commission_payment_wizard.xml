<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_commission_payment" model="ir.ui.view">
        <field name="name">pos.make.payment.form</field>
        <field name="model">commission.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Pay Order">
                <group>
                    <group>
                        <field name="journal_id" />
                        <field name="pos_card_commission_ids" widget="many2many_tags" readonly="1" invisible="1"/>
                        <field name="date"/>
                        <!-- <field name="payment_method_id"/> -->
                    </group>
                    <group>
                        <field name="res_card_commission_id" readonly="1" invisible="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="amount" />
                        <field name="payment_name"/>
                    </group>
                </group>
                <footer>
                    <button name="commission_payment" string="Make Payment" type="object" class="btn-primary" data-hotkey="q"/>
                    <button special="cancel" data-hotkey="z" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    
    <record id="action_card_commission_payment" model="ir.actions.act_window">
        <field name="name">Payment</field>
        <field name="res_model">commission.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
