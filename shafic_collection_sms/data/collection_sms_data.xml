<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_collection_sms_batch" model="ir.sequence">
            <field name="name">Debt Collection SMS Batch</field>
            <field name="code">collection.sms.batch</field>
            <field name="prefix">COLL/%(year)s/%(month)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="cron_collection_month_end" model="ir.cron">
            <field name="name">Debt Collection: Prepare Month-End SMS Batch</field>
            <field name="model_id" ref="model_collection_sms_batch"/>
            <field name="state">code</field>
            <field name="code">model._cron_prepare_month_end()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall"
                   eval="(datetime.now().replace(hour=22, minute=0, second=0, microsecond=0))"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
