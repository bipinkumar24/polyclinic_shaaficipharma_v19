<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_form_add_discount" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.pos.discount</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='product_and_category_block']" position="after">
                <block id="pos_global_discount" title="Pos Global Discount">
                    <setting help="Enable Pos Global Discount">
                        <field name="enable_discount" readonly="pos_has_active_session"/>
                        <div class="content-group mt16" invisible="not enable_discount">
                            <field name="global_discount_type" readonly="pos_has_active_session"/>
                        </div>
                        <div class="content-group mt16" invisible="not enable_discount">
                            <field name="global_discount_product_id" readonly="pos_has_active_session"/>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
