<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Show the treating physician on the invoice, next to the customer. -->
    <record id="view_move_form_shafic_physician" model="ir.ui.view">
        <field name="name">account.move.form.shafic.physician</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="physician_id"
                       invisible="move_type != 'out_invoice'"
                       options="{'no_create': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>

</odoo>
