<odoo>
	 <record id="patient_laboratory_test_request_card_form" model="ir.ui.view">
        <field name="name">acs.laboratory.request.from</field>
        <field name="model">acs.laboratory.request</field>
        <field name="inherit_id" ref="acs_laboratory.patient_laboratory_test_request_form"/>
        <field name="arch" type="xml">
            <field name="acs_no_lab_result" position="after">
               <field name="available_insurancecard_balance_lab" readonly="insurance_readonly"/>
               <field name="new_insurance_company_id" required="available_insurancecard_balance_lab" invisible="not available_insurancecard_balance_lab" readonly="insurance_readonly"/>
               <field name="card_insurance_company_id" invisible="1"/>
               <field name="insurancecard_balance_amount" invisible="1" readonly="insurance_readonly"/>
               <field name="insurancecard_total_amount" invisible="not available_insurancecard_balance_lab" readonly="insurance_readonly" groups="acs_hms_pharmacy.group_show_amounts_on_prescription"/>
               <field name="insurance_covers_amount" invisible="not available_insurancecard_balance_lab" readonly="insurance_readonly"/>
               <field name="patient_pay_amount" invisible="not available_insurancecard_balance_lab" readonly="insurance_readonly" groups="acs_hms_pharmacy.group_show_amounts_on_prescription"/>
            </field>
            <field name="patient_id" position="after">
                <field name="show_price" invisible="1"/>
            </field>

            <xpath expr="//field[@name='line_ids']//field[@name='sale_price']" position="attributes">
               <attribute name="column_invisible">not parent.show_price</attribute>
            </xpath>
            <xpath expr="//field[@name='total_price']" position="attributes">
               <attribute name="groups">acs_hms_pharmacy.group_show_amounts_on_prescription</attribute>
            </xpath>
        </field>
    </record>
</odoo>