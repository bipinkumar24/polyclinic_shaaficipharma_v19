<?xml version="1.0"?>
<odoo>
    <!-- Appointment View -->
    <record id="view_hms_appointment_field_form" model="ir.ui.view">
        <field name="name">hms.appointment.form</field>
        <field name="model">hms.appointment</field>
        <field name="inherit_id" ref="acs_hms.view_hms_appointment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="is_invoice" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="available_insurancecard_balance" readonly="insurance_readonly"/>
                <field name="new_insurance_company_id" required="available_insurancecard_balance" invisible="not available_insurancecard_balance" readonly="insurance_readonly"/>
                <field name="card_insurance_company_id" invisible="0" />
                <field name="insurancecard_balance_amount" invisible="1" readonly="insurance_readonly"/>
                <field name="insurancecard_total_amount" invisible="not available_insurancecard_balance" readonly="insurance_readonly" groups="acs_hms_pharmacy.group_show_amounts_on_prescription"/>
                <field name="insurance_covers_amount" invisible="not available_insurancecard_balance" readonly="insurance_readonly"/>
                <field name="patient_pay_amount" invisible="not available_insurancecard_balance" readonly="insurance_readonly" groups="acs_hms_pharmacy.group_show_amounts_on_prescription"/>
            </xpath>
            <button name="appointment_consultation" position="attributes">
                <attribute name="groups">acs_hms.group_hms_jr_doctor,acs_hms_aesthetic.group_hms_aesthetic,do_insurance_card_balance_system.group_hms_allow_consultant_receptionist</attribute>
            </button>
        </field>
    </record>
</odoo>