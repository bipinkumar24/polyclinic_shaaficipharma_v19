<odoo>
	<record id="view_patient_new_form" model="ir.ui.view">
		<field name="name">patient.form</field>
		<field name="model">hms.patient</field>
		<field name="inherit_id" ref="acs_hms_base.view_patient_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='acs_tag_ids']" position="after">
	            <field name="new_insurance_company_id" options="{'no_create': True}"/>
	        </xpath>
		</field>
	</record>
</odoo>
