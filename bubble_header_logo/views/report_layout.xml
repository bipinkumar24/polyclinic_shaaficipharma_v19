<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="external_layout_bubble_custom"
              inherit_id="web.external_layout_bubble"
              name="Custom Bubble Header">

        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">
            <div t-attf-class="header o_company_#{company.id}_layout {{report_type == 'pdf' and 'pt-5'}}"
                 style="position: relative; padding: 0; margin: 0;">

                <img
                    t-attf-src="/bubble_header_logo/static/src/img/logo.png"
                    style="width: 100%; height: 150px; object-fit: cover; display: block;"
                    alt="Header Background"
                />

            </div>
        </xpath>

    </template>
