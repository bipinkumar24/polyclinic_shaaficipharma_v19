<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="pos_order_line_multi_uom" model="ir.ui.view">
            <field name="name">UOM for Order line</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_pos_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="uom" position="after" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='lines']/list/field[@name='qty']" position="after">
                    <field name="custom_uom_id" column_invisible = 'parent.uom == False' />
                    <field name="second_uom_id" column_invisible = 'parent.uom == False' />
                    <field name="custom_qty" column_invisible = 'parent.uom == False' />
                </xpath>
                <xpath expr="//field[@name='lines']//list//field[@name='product_uom_id']" position="attributes">
                    <field name="product_uom_id" position="attributes">
                        <attribute name="column_invisible">1</attribute>
                    </field>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
