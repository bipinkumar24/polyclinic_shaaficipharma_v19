<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_hms" model="ir.module.category">
            <field name="name">Hospital</field>
            <field name="description">Hospital Management System</field>
            <field name="sequence">9</field>
        </record>

        <record id="module_category_hms_department" model="ir.module.category">
            <field name="name">Hospital (Department)</field>
            <field name="description">Hospital Management System Department Level Access</field>
            <field name="sequence">10</field>
        </record>

        <record id="module_category_hms_speciality" model="ir.module.category">
            <field name="name">Hospital (Speciality)</field>
            <field name="description">Hospital Management System Speciality Access</field>
            <field name="sequence">10</field>
        </record>

        <record id="module_category_hms_extra" model="ir.module.category">
            <field name="name">Hospital Extra</field>
            <field name="description">Hospital Management System Extra</field>
            <field name="sequence">12</field>
        </record>

        <!-- Odoo 19: res.groups.category_id was replaced by privilege_id (res.groups.privilege),
             which now carries the ir.module.category. -->
        <record id="privilege_hms" model="res.groups.privilege">
            <field name="name">Hospital</field>
            <field name="category_id" ref="module_category_hms"/>
        </record>

        <record id="privilege_hms_extra" model="res.groups.privilege">
            <field name="name">Hospital Extra</field>
            <field name="category_id" ref="module_category_hms_extra"/>
        </record>

        <record id="privilege_hms_department" model="res.groups.privilege">
            <field name="name">Hospital (Department)</field>
            <field name="category_id" ref="module_category_hms_department"/>
        </record>

        <record id="privilege_hms_speciality" model="res.groups.privilege">
            <field name="name">Hospital (Speciality)</field>
            <field name="category_id" ref="module_category_hms_speciality"/>
        </record>

        <record id="group_hms_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_hms"/>
        </record>

        <record id="group_hms_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_hms"/>
            <field name="implied_ids" eval="[(4, ref('group_hms_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id ="group_manage_services" model="res.groups">
            <field name="name">Manage Services</field>
            <field name="privilege_id" ref="acs_hms_base.privilege_hms_extra"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id ="group_manage_medicines" model="res.groups">
            <field name="name">Manage Medicines</field>
            <field name="privilege_id" ref="acs_hms_base.privilege_hms_extra"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_acs_invoice_exemption" model="res.groups">
            <field name="name">Allow Invoice Exemption</field>
            <field name="privilege_id" ref="acs_hms_base.privilege_hms_extra"/>
        </record>

        <record id="group_acs_invoice_exemption_request" model="res.groups">
            <field name="name">Allow Invoice Exemption Request</field>
            <field name="privilege_id" ref="acs_hms_base.privilege_hms_extra"/>
        </record>

        <record id ="group_manage_ethnic_religion_tribe" model="res.groups">
            <field name="name">Manage Religion/Tribe/Ethnic group</field>
            <field name="privilege_id" ref="acs_hms_base.privilege_hms_extra"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>