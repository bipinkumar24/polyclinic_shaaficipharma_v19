<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_vaccination" model="ir.actions.act_window">
        <field name="name">Vaccination</field>
        <field name="path">almightyhms-cashier-vaccination</field>
        <field name="res_model">acs.vaccination</field>
        <field name="view_mode">list,form,calendar,pivot</field>
        <field name="context">
            {
                'create': False,
                'edit': False,
                'delete': False
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Click to add a Vaccination.
            </p>
        </field>
    </record>
     <record id="action_vaccination_invoice" model="ir.actions.act_window">
        <field name="name">Vaccination</field>
        <field name="res_model">acs.vaccination</field>
        <field name="view_mode">list,form,calendar,pivot</field>
        <field name="domain">[('invoice_id','=',False),('state','=','to_invoice')]</field>
        <field name="context">
            {
                'create': False,
                'edit': False,
                'delete': False
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Click to add a Vaccination.
            </p>
        </field>
    </record>

    <record id="action_vaccination_cashier_invoice" model="ir.actions.act_window">
        <field name="name">Vaccination To Invoice</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>

        <!-- Domain uses context -->
        <field name="domain">
            [
                ('move_type', '=', 'out_invoice'),
                ("hospital_invoice_type", "=", "vaccination")
            ]
        </field>
    </record>

</odoo>