<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_acs_cashier" model="res.groups">
        <field name="name">Cashier</field>
        <field name="privilege_id" ref="acs_hms_base.privilege_hms_department"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_radiology_user" model="res.groups">
        <field name="name">Only Radiology Requests</field>
    </record>

    <record id="group_laboratory_request" model="res.groups">
        <field name="name">Only Laboratory Requests</field>
    </record>

</odoo>
