<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_single_invoice_user" model="ir.sequence">
            <field name="name">Single Invoice</field>
            <field name="code">acs.hms.invoice</field>
            <field name="prefix">SI</field>
            <field name="padding">3</field>
            <field name="acs_auto_create" eval="True"/>
            <field name="company_id" eval="False"/>
        </record>

    </data>
    <record id="cron_sync_hms_patient_partner" model="ir.cron">
        <field name="name">Sync HMS Patient → Partner</field>
        <field name="model_id" ref="acs_hms_base.model_hms_patient"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_patient_partners()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">False</field>
    </record>
</odoo>
