<templates xml:space="preserve">
    <t t-name="wk_pos_credit_limit.PosCreditLimitPopup">
        <Dialog title="props.title">
            <p class="text-prewrap">
                <b><t t-esc="props.partner" /></b>
                <t t-esc="props.message" />
            </p>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="() => props.close()">OK</button>
            </t>
        </Dialog>
    </t>
</templates>