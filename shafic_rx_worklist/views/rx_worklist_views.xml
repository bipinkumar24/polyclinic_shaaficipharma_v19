<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_rx_worklist_list" model="ir.ui.view">
        <field name="name">prescription.order.rx.worklist.list</field>
        <field name="model">prescription.order</field>
        <field name="arch" type="xml">
            <list string="Pending Prescriptions" create="false"
                  edit="false"
                  decoration-muted="acs_rx_dispensed"
                  default_order="prescription_date desc">
                <field name="name"/>
                <field name="prescription_date"/>
                <field name="patient_id"/>
                <field name="physician_id"/>
                <field name="acs_rx_member_tier"/>
                <field name="acs_rx_est_value"/>
                <field name="acs_rx_dispensed" optional="show"/>
                <button name="action_mark_dispensed" type="object"
                        string="Mark Dispensed" icon="fa-check"
                        invisible="acs_rx_dispensed"/>
            </list>
        </field>
    </record>

    <record id="view_rx_worklist_form" model="ir.ui.view">
        <field name="name">prescription.order.rx.worklist.form</field>
        <field name="model">prescription.order</field>
        <field name="arch" type="xml">
            <form string="Prescription" create="false">
                <header>
                    <button name="action_print_slip" type="object"
                            string="Print Slip" icon="fa-qrcode"/>
                    <button name="action_mark_dispensed" type="object"
                            string="Mark Dispensed" class="btn-primary"
                            invisible="acs_rx_dispensed"/>
                    <button name="action_unmark_dispensed" type="object"
                            string="Undo Dispensed"
                            invisible="not acs_rx_dispensed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id" readonly="1"/>
                            <field name="physician_id" readonly="1"/>
                            <field name="prescription_date" readonly="1"/>
                            <field name="state" readonly="1"/>
                        </group>
                        <group>
                            <field name="acs_rx_member_tier"/>
                            <field name="acs_rx_est_value"/>
                            <field name="acs_rx_dispensed" readonly="1"/>
                            <field name="acs_rx_dispensed_date"/>
                            <field name="acs_rx_dispensed_by"/>
                        </group>
                    </group>
                    <field name="prescription_line_ids" readonly="1">
                        <list create="false" edit="false">
                            <field name="product_id"/>
                            <field name="quantity" string="Qty (pieces)"/>
                            <field name="dose"/>
                            <field name="acs_rx_unit_price"/>
                            <field name="acs_rx_line_value"/>
                            <field name="qty_available"
                                   string="On Hand"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rx_worklist_search" model="ir.ui.view">
        <field name="name">prescription.order.rx.worklist.search</field>
        <field name="model">prescription.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="patient_id"/>
                <field name="physician_id"/>
                <field name="name"/>
                <filter name="pending" string="Pending"
                        domain="[('acs_rx_dispensed', '=', False)]"/>
                <filter name="dispensed" string="Dispensed"
                        domain="[('acs_rx_dispensed', '=', True)]"/>
                <group>
                    <filter name="g_physician" string="Physician"
                            context="{'group_by': 'physician_id'}"/>
                    <filter name="g_patient" string="Patient"
                            context="{'group_by': 'patient_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rx_worklist" model="ir.actions.act_window">
        <field name="name">Pending Prescriptions</field>
        <field name="res_model">prescription.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'prescription')]</field>
        <field name="search_view_id" ref="view_rx_worklist_search"/>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No prescriptions waiting
            </p>
            <p>
                Confirmed prescriptions from the clinic appear here for the
                pharmacy to dispense. Ring the items up at POS, then use
                Mark Dispensed to clear them from the queue.
            </p>
        </field>
    </record>

    <record id="rx_worklist_act_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_rx_worklist_list"/>
        <field name="act_window_id" ref="action_rx_worklist"/>
    </record>
    <record id="rx_worklist_act_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_rx_worklist_form"/>
        <field name="act_window_id" ref="action_rx_worklist"/>
    </record>

    <menuitem id="menu_rx_worklist" name="Pending Prescriptions"
              parent="point_of_sale.menu_point_root"
              action="action_rx_worklist" sequence="20"
              groups="point_of_sale.group_pos_user"/>

</odoo>
