<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_discount_form_inherit" model="ir.ui.view">
        <field name="name">view.account.payment.invoice.form.inherit.discount</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="apply_discount" default="False"/>
                <field name="discount_type" invisible="not apply_discount"/>
                <field name="discount_amount" invisible="discount_type != 'fixed'"/>
                <field name="percentage" invisible="discount_type != 'percentage'"/>
            </xpath>
        </field>
    </record>
</odoo>