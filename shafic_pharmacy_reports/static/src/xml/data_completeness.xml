<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="shafic_pharmacy_reports.PharmacyDataCompleteness">
        <div class="o_pharmacy_data_completeness p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">Data Completeness</h2>
                <button class="btn btn-sm btn-outline-secondary"
                        t-on-click="loadData">
                    Refresh
                </button>
            </div>

            <div t-if="state.loading" class="text-center text-muted py-5">
                Loading...
            </div>

            <div t-else="">
                <!-- Headline tiles -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3 col-6">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <div class="text-muted small">Overall</div>
                                <div class="h2 mb-0"
                                     t-att-class="pctClass(state.data.pct_complete)">
                                    <t t-esc="state.data.pct_complete"/>%
                                </div>
                                <div class="text-muted small">
                                    <t t-esc="state.data.complete"/> of
                                    <t t-esc="state.data.total"/> complete
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="card h-100 cursor-pointer"
                             style="cursor: pointer;"
                             t-on-click="openIncomplete">
                            <div class="card-body text-center">
                                <div class="text-muted small">Incomplete</div>
                                <div class="h2 mb-0 text-danger">
                                    <t t-esc="state.data.incomplete"/>
                                </div>
                                <div class="text-muted small">Click to view</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="card h-100 cursor-pointer"
                             style="cursor: pointer;"
                             t-on-click="() => this.openMissingField('missing_barcode')">
                            <div class="card-body text-center">
                                <div class="text-muted small">Missing Barcode</div>
                                <div class="h3 mb-0 text-warning">
                                    <t t-esc="state.data.missing_barcode"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="card h-100 cursor-pointer"
                             style="cursor: pointer;"
                             t-on-click="() => this.openMissingField('missing_ref')">
                            <div class="card-body text-center">
                                <div class="text-muted small">Missing Reference</div>
                                <div class="h3 mb-0 text-warning">
                                    <t t-esc="state.data.missing_ref"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-3 col-6">
                        <div class="card h-100 cursor-pointer"
                             style="cursor: pointer;"
                             t-on-click="() => this.openMissingField('missing_lot')">
                            <div class="card-body text-center">
                                <div class="text-muted small">Missing Lot / Batch</div>
                                <div class="h3 mb-0 text-warning">
                                    <t t-esc="state.data.missing_lot"/>
                                </div>
                                <div class="text-muted small">
                                    For lot/serial-tracked products
                                </div>
                            </div>
                        </div>
                    </div>
                    <div t-if="state.data.checksum_enabled" class="col-md-3 col-6">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <div class="text-muted small">Bad Barcode Checksum</div>
                                <div class="h3 mb-0 text-danger">
                                    <t t-esc="state.data.failed_checksum"/>
                                </div>
                                <div class="text-muted small">
                                    Barcodes that fail GTIN check digit
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Completeness by pharmacy category -->
                <div class="card mb-4">
                    <div class="card-header">
                        <strong>Completeness by Pharmacy Category</strong>
                        <span class="text-muted ms-2 small">
                            Click a row to see incomplete products in that category
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Category</th>
                                    <th class="text-end">Complete</th>
                                    <th class="text-end">Incomplete</th>
                                    <th class="text-end" style="width: 30%;">Completeness</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.data.by_category" t-as="cat"
                                    t-key="cat.key"
                                    style="cursor: pointer;"
                                    t-on-click="() => this.openCategory(cat.key)">
                                    <td><t t-esc="cat.label"/></td>
                                    <td class="text-end text-success">
                                        <t t-esc="cat.complete"/>
                                    </td>
                                    <td class="text-end text-danger">
                                        <t t-esc="cat.incomplete"/>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1"
                                                 style="height: 8px;">
                                                <div class="progress-bar"
                                                     t-att-class="barClass(cat.pct_complete)"
                                                     t-att-style="'width: ' + barWidth(cat.pct_complete)"/>
                                            </div>
                                            <span class="small fw-bold"
                                                  t-att-class="pctClass(cat.pct_complete)"
                                                  style="min-width: 50px; text-align: right;">
                                                <t t-esc="cat.pct_complete"/>%
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <p class="text-muted small">
                    A product is complete when it has a valid barcode, an
                    internal reference, and (when lot/serial tracked) at
                    least one batch on record. These rules match the
                    bonus scorecard's data-completeness KPI exactly.
                </p>
            </div>
        </div>
    </t>

</templates>
