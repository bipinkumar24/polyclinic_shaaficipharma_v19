<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_report_cashier_performance_list" model="ir.ui.view">
        <field name="name">report.pharmacy.cashier.performance.list</field>
        <field name="model">report.pharmacy.cashier.performance</field>
        <field name="arch" type="xml">
            <list string="Cashier Performance" create="false" edit="false">
                <field name="order_date"/>
                <field name="cashier_id"/>
                <field name="branch_id"/>
                <field name="revenue" sum="Sales Generated"/>
                <field name="transaction_count" sum="Transactions"/>
                <field name="avg_ticket" avg="Avg Ticket"/>
                <field name="discount_total" sum="Discount Given"/>
                <field name="refund_total" sum="Refund Value"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_report_cashier_performance_pivot" model="ir.ui.view">
        <field name="name">report.pharmacy.cashier.performance.pivot</field>
        <field name="model">report.pharmacy.cashier.performance</field>
        <field name="arch" type="xml">
            <pivot string="Cashier Performance Analysis">
                <field name="cashier_id" type="row"/>
                <field name="revenue" type="measure"/>
                <field name="discount_total" type="measure"/>
                <field name="refund_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_cashier_performance_graph" model="ir.ui.view">
        <field name="name">report.pharmacy.cashier.performance.graph</field>
        <field name="model">report.pharmacy.cashier.performance</field>
        <field name="arch" type="xml">
            <graph string="Cashier Performance Analysis" type="bar">
                <field name="cashier_id"/>
                <field name="revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_cashier_performance_search" model="ir.ui.view">
        <field name="name">report.pharmacy.cashier.performance.search</field>
        <field name="model">report.pharmacy.cashier.performance</field>
        <field name="arch" type="xml">
            <search string="Cashier Performance">
                <field name="cashier_id"/>
                <field name="branch_id"/>
                <filter name="this_month" string="This Month"
                        domain="[('order_date', '&gt;=',
                                 (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group name="group_by">
                    <filter name="group_cashier" string="Cashier"
                            context="{'group_by': 'cashier_id'}"/>
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'order_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_cashier_performance"
            model="ir.actions.act_window">
        <field name="name">Cashier Performance</field>
        <field name="res_model">report.pharmacy.cashier.performance</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id"
               ref="view_report_cashier_performance_search"/>
    </record>

</odoo>
