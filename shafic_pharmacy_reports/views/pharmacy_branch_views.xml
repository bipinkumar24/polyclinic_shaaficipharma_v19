<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_branch_list" model="ir.ui.view">
        <field name="name">pharmacy.branch.list</field>
        <field name="model">pharmacy.branch</field>
        <field name="arch" type="xml">
            <list string="Pharmacy Branches">
                <field name="code"/>
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="manager_id"/>
                <field name="phone"/>
                <field name="sales_target"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_branch_form" model="ir.ui.view">
        <field name="name">pharmacy.branch.form</field>
        <field name="model">pharmacy.branch</field>
        <field name="arch" type="xml">
            <form string="Pharmacy Branch">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Branch Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="warehouse_id"/>
                            <field name="manager_id"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="address"/>
                            <field name="sales_target"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="POS Points" name="pos">
                            <field name="pos_config_ids"
                                   widget="many2many_tags"/>
                        </page>
                        <page string="Pharmacists" name="pharmacists">
                            <field name="pharmacist_ids"
                                   widget="many2many_tags"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pharmacy_branch_search" model="ir.ui.view">
        <field name="name">pharmacy.branch.search</field>
        <field name="model">pharmacy.branch</field>
        <field name="arch" type="xml">
            <search string="Pharmacy Branches">
                <field name="name"/>
                <field name="code"/>
                <field name="manager_id"/>
                <filter name="archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_manager" string="Manager"
                            context="{'group_by': 'manager_id'}"/>
                    <filter name="group_company" string="Company"
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacy_branch" model="ir.actions.act_window">
        <field name="name">Pharmacy Branches</field>
        <field name="res_model">pharmacy.branch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pharmacy_branch_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first pharmacy branch
            </p>
        </field>
    </record>

</odoo>
