<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_form_pharmacy" model="ir.ui.view">
        <field name="name">product.template.form.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id"
               ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Cost/UoM mismatch warning banner (non-blocking). Appears
                 above the form body whenever the cost looks wrong vs the
                 price. -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning" role="alert"
                     invisible="not pharmacy_cost_warning">
                    <field name="pharmacy_cost_warning" readonly="1"/>
                </div>
            </xpath>
            <!-- Show weighted-avg cost next to the standard Cost field
                 on the General Information tab. Read-only, informational
                 - lets users see when standard_price drifts from the
                 real warehouse-wise cost. -->
            <xpath expr="//field[@name='standard_price']" position="after">
                <field name="pharmacy_weighted_avg_cost"
                       readonly="1"
                       help="Weighted-average warehouse cost (from the Warehouse-Wise Cost module). Shown here for comparison with the Cost field above."/>
                <field name="pharmacy_cost_source"
                       widget="badge"
                       decoration-success="pharmacy_cost_source == 'warehouse'"
                       decoration-warning="pharmacy_cost_source == 'standard'"
                       decoration-danger="pharmacy_cost_source == 'zero'"
                       readonly="1"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Pharmacy" name="pharmacy">
                    <group>
                        <group string="Classification">
                            <field name="pharmacy_category_id"/>
                            <field name="active_ingredient"/>
                            <field name="storage_condition"/>
                        </group>
                        <group string="Regulatory">
                            <field name="is_controlled_drug"/>
                            <field name="requires_prescription"/>
                            <field name="drug_schedule"
                                   invisible="not is_controlled_drug"/>
                        </group>
                        <group string="Reorder Levels">
                            <field name="reorder_min_qty"/>
                            <field name="reorder_max_qty"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_list_pharmacy" model="ir.ui.view">
        <field name="name">product.template.list.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="default_code" position="after">
                <field name="pharmacy_category_id" optional="show"/>
                <field name="is_controlled_drug" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="view_product_template_search_pharmacy" model="ir.ui.view">
        <field name="name">product.template.search.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <filter name="goods" position="after">
                <separator/>
                <filter name="controlled_drug" string="Controlled Drugs"
                        domain="[('is_controlled_drug', '=', True)]"/>
                <filter name="rx_required" string="Prescription Required"
                        domain="[('requires_prescription', '=', True)]"/>
                <separator/>
                <filter name="group_pharmacy_category"
                        string="Pharmacy Category"
                        context="{'group_by': 'pharmacy_category_id'}"/>
            </filter>
        </field>
    </record>

</odoo>
