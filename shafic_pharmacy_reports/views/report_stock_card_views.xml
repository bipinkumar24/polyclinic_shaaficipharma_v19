<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_report_stock_card_list" model="ir.ui.view">
        <field name="name">report.pharmacy.stock.card.list</field>
        <field name="model">report.pharmacy.stock.card</field>
        <field name="arch" type="xml">
            <list string="Stock Card" create="false" edit="false"
                  default_order="date desc, id desc"
                  decoration-success="move_kind == 'in'"
                  decoration-danger="move_kind == 'out'">
                <field name="date"/>
                <field name="product_id"/>
                <field name="reference" optional="show"/>
                <field name="move_kind" optional="show"/>
                <field name="qty_in" sum="Total In"/>
                <field name="qty_out" sum="Total Out"/>
                <field name="balance_qty"/>
                <field name="unit_cost" optional="show"/>
                <field name="value" sum="Net Value" optional="show"/>
                <field name="balance_value"/>
                <field name="pharmacy_category_id" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <button name="action_open_source" type="object"
                        string="Source" icon="fa-external-link"
                        help="Open the source document"/>
            </list>
        </field>
    </record>

    <record id="view_report_stock_card_search" model="ir.ui.view">
        <field name="name">report.pharmacy.stock.card.search</field>
        <field name="model">report.pharmacy.stock.card</field>
        <field name="arch" type="xml">
            <search string="Stock Card">
                <field name="product_id"/>
                <field name="pharmacy_category_id"/>
                <field name="reference"/>
                <filter name="moves_in" string="Receipts (In)"
                        domain="[('move_kind', '=', 'in')]"/>
                <filter name="moves_out" string="Issues (Out)"
                        domain="[('move_kind', '=', 'out')]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('date', '&gt;=',
                                 (context_today().strftime('%Y-%m-%d 00:00:00')))]"/>
                <filter name="this_month" string="This Month"
                        domain="[('date', '&gt;=',
                                 (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="last_year" string="Last 365 Days"
                        domain="[('date', '&gt;=',
                                 ((context_today() + relativedelta(years=-1))
                                  .strftime('%Y-%m-%d 00:00:00')))]"/>
                <separator/>
                <filter name="date_filter" string="Date" date="date"/>
                <group name="group_by">
                    <filter name="group_product" string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_category" string="Pharmacy Category"
                            context="{'group_by': 'pharmacy_category_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_stock_card" model="ir.actions.act_window">
        <field name="name">Stock Card</field>
        <field name="res_model">report.pharmacy.stock.card</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_report_stock_card_search"/>
        <field name="context">{'search_default_group_product': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No stock movements yet
            </p>
            <p>
                The Stock Card is an item ledger: every receipt, sale and
                adjustment in date order, with a running quantity and value
                balance per product. Filter by product and date to see the
                history for any item and period. The balance columns always
                reflect the true cumulative position, even when filtered.
            </p>
        </field>
    </record>

</odoo>
