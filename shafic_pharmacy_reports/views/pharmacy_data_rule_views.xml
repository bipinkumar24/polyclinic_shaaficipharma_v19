<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_data_rule_list" model="ir.ui.view">
        <field name="name">pharmacy.data.rule.list</field>
        <field name="model">pharmacy.data.rule</field>
        <field name="arch" type="xml">
            <list string="Data Quality Rules">
                <field name="field_key"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="min_length"/>
                <field name="regex_pattern"/>
                <field name="enforce_checksum" widget="boolean_toggle"
                       optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_data_rule_form" model="ir.ui.view">
        <field name="name">pharmacy.data.rule.form</field>
        <field name="model">pharmacy.data.rule</field>
        <field name="arch" type="xml">
            <form string="Data Quality Rule">
                <sheet>
                    <div class="oe_title">
                        <label for="field_key" string="Field"/>
                        <h1><field name="field_key"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="min_length"/>
                            <field name="regex_pattern"
                                   placeholder="e.g. ^[A-Z0-9-]{4,}$"/>
                            <field name="enforce_checksum"
                                   invisible="field_key != 'barcode'"/>
                        </group>
                        <group>
                            <label for="description" string="What this rule means"/>
                            <field name="description" nolabel="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Changes to rules apply to the bonus calculation the
                        next time the scorecard is opened. The data
                        completeness SQL view is rebuilt on module upgrade —
                        if you change min_length or regex, click
                        <b>Apply Rules to View</b> below or upgrade the
                        module to refresh.
                    </div>
                    <div>
                        <button name="action_refresh_view"
                                type="object"
                                string="Apply Rules to View"
                                class="oe_highlight"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pharmacy_data_rule" model="ir.actions.act_window">
        <field name="name">Data Quality Rules</field>
        <field name="res_model">pharmacy.data.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
