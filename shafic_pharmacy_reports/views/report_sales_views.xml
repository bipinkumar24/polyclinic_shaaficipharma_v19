<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_report_sales_list" model="ir.ui.view">
        <field name="name">report.pharmacy.sales.list</field>
        <field name="model">report.pharmacy.sales</field>
        <field name="arch" type="xml">
            <list string="POS Sales" create="false" edit="false"
                  decoration-danger="is_refund == True">
                <field name="order_date"/>
                <field name="order_id"/>
                <field name="branch_id"/>
                <field name="cashier_id"/>
                <field name="product_id"/>
                <field name="pharmacy_category_id"/>
                <field name="partner_id" optional="hide"/>
                <field name="qty" sum="Total Qty"/>
                <field name="price_subtotal" sum="Net Sales"/>
                <field name="price_total" sum="Gross Sales"/>
                <field name="tax_amount" sum="Taxes" optional="hide"/>
                <field name="discount_amount" sum="Discounts"/>
                <field name="cost" sum="Cost" optional="hide"/>
                <field name="margin" sum="Margin"/>
                <field name="is_refund" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_report_sales_pivot" model="ir.ui.view">
        <field name="name">report.pharmacy.sales.pivot</field>
        <field name="model">report.pharmacy.sales</field>
        <field name="arch" type="xml">
            <pivot string="POS Sales Analysis">
                <field name="branch_id" type="row"/>
                <field name="order_date" interval="month" type="col"/>
                <field name="price_subtotal" type="measure"/>
                <field name="margin" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_sales_graph" model="ir.ui.view">
        <field name="name">report.pharmacy.sales.graph</field>
        <field name="model">report.pharmacy.sales</field>
        <field name="arch" type="xml">
            <graph string="POS Sales Analysis" type="line">
                <field name="order_date" interval="day"/>
                <field name="price_subtotal" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_sales_search" model="ir.ui.view">
        <field name="name">report.pharmacy.sales.search</field>
        <field name="model">report.pharmacy.sales</field>
        <field name="arch" type="xml">
            <search string="POS Sales">
                <field name="product_id"/>
                <field name="branch_id"/>
                <field name="cashier_id"/>
                <field name="partner_id"/>
                <filter name="today" string="Today"
                        domain="[('order_date', '&gt;=',
                                 datetime.datetime.combine(context_today(),
                                 datetime.time(0,0,0)))]"/>
                <filter name="this_month" string="This Month"
                        domain="[('order_date', '&gt;=',
                                 (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="sales_only" string="Sales Only"
                        domain="[('is_refund', '=', False)]"/>
                <filter name="refunds_only" string="Refunds Only"
                        domain="[('is_refund', '=', True)]"/>
                <group name="group_by">
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_cashier" string="Cashier"
                            context="{'group_by': 'cashier_id'}"/>
                    <filter name="group_category" string="Pharmacy Category"
                            context="{'group_by': 'pharmacy_category_id'}"/>
                    <filter name="group_product" string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_date" string="Order Date"
                            context="{'group_by': 'order_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_sales" model="ir.actions.act_window">
        <field name="name">POS Sales Analysis</field>
        <field name="res_model">report.pharmacy.sales</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_report_sales_search"/>
    </record>

</odoo>
