<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_prescription_list" model="ir.ui.view">
        <field name="name">pharmacy.prescription.list</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <list string="Prescriptions"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'dispensed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="prescription_date"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="branch_id"/>
                <field name="pharmacist_id"/>
                <field name="pos_order_count" string="POS Orders"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'dispensed'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_prescription_form" model="ir.ui.view">
        <field name="name">pharmacy.prescription.form</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <form string="Prescription">
                <header>
                    <button name="action_validate" type="object"
                            string="Validate" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_dispense" type="object"
                            string="Mark Dispensed" class="btn-primary"
                            invisible="state != 'validated'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('dispensed', 'cancelled')"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,validated,dispensed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_pos_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="pos_order_count == 0">
                            <field name="pos_order_count" widget="statinfo"
                                   string="POS Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="prescription_date"/>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                        </group>
                        <group>
                            <field name="branch_id"/>
                            <field name="pharmacist_id"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Prescription Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="dosage"/>
                                    <field name="duration_days"/>
                                    <field name="is_controlled"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_prescription_search" model="ir.ui.view">
        <field name="name">pharmacy.prescription.search</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <search string="Prescriptions">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="branch_id"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="validated" string="Validated"
                        domain="[('state', '=', 'validated')]"/>
                <filter name="dispensed" string="Dispensed"
                        domain="[('state', '=', 'dispensed')]"/>
                <group name="group_by">
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_doctor" string="Doctor"
                            context="{'group_by': 'doctor_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_date" string="Prescription Date"
                            context="{'group_by': 'prescription_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_prescription" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">pharmacy.prescription</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_prescription_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first prescription
            </p>
        </field>
    </record>

</odoo>
