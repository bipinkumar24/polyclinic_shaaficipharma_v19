<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_expiry_action_list" model="ir.ui.view">
        <field name="name">pharmacy.expiry.action.list</field>
        <field name="model">pharmacy.expiry.action</field>
        <field name="arch" type="xml">
            <list string="Catch Actions">
                <field name="action_date"/>
                <field name="action_type"/>
                <field name="product_id"/>
                <field name="lot_id" optional="show"/>
                <field name="expiry_date" optional="show"/>
                <field name="quantity" optional="hide"/>
                <field name="value_at_risk" sum="Value at Risk"/>
                <field name="user_id" optional="show"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_expiry_action_form" model="ir.ui.view">
        <field name="name">pharmacy.expiry.action.form</field>
        <field name="model">pharmacy.expiry.action</field>
        <field name="arch" type="xml">
            <form string="Catch Action">
                <sheet>
                    <group>
                        <group>
                            <field name="action_date"/>
                            <field name="action_type"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="expiry_date"/>
                        </group>
                        <group>
                            <field name="quantity"/>
                            <field name="value_at_risk"/>
                            <field name="user_id"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pharmacy_expiry_action_search" model="ir.ui.view">
        <field name="name">pharmacy.expiry.action.search</field>
        <field name="model">pharmacy.expiry.action</field>
        <field name="arch" type="xml">
            <search string="Catch Actions">
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="user_id"/>
                <filter name="this_month" string="This Month"
                        domain="[('year', '=', context_today().year),
                                 ('month', '=', context_today().month)]"/>
                <separator/>
                <filter name="discount" string="Discount"
                        domain="[('action_type', '=', 'discount')]"/>
                <filter name="supplier_return" string="Supplier Return"
                        domain="[('action_type', '=', 'supplier_return')]"/>
                <filter name="transfer" string="Transfer"
                        domain="[('action_type', '=', 'transfer')]"/>
                <filter name="clearance" string="Clearance"
                        domain="[('action_type', '=', 'clearance')]"/>
                <group name="group_by">
                    <filter name="group_type" string="Action Type"
                            context="{'group_by': 'action_type'}"/>
                    <filter name="group_user" string="Recorded By"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'action_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacy_expiry_action" model="ir.actions.act_window">
        <field name="name">Expiry Catch Actions</field>
        <field name="res_model">pharmacy.expiry.action</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id"
               ref="view_pharmacy_expiry_action_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Catches recorded here count toward the bonus
            </p>
            <p>
                These rows are created when you use the action menu on
                the Expiry Report to record a discount, supplier return,
                transfer, or clearance. They are the real "catches" that
                feed the bonus scorecard's caught-early KPI.
            </p>
        </field>
    </record>

</odoo>
