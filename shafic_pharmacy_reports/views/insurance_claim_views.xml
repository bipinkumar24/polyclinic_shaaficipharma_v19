<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_insurance_claim_list" model="ir.ui.view">
        <field name="name">pharmacy.insurance.claim.list</field>
        <field name="model">pharmacy.insurance.claim</field>
        <field name="arch" type="xml">
            <list string="Insurance Claims"
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('submitted', 'partial')"
                  decoration-success="state in ('approved', 'paid')"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="claim_date"/>
                <field name="provider_id"/>
                <field name="patient_id"/>
                <field name="branch_id"/>
                <field name="claim_amount"/>
                <field name="approved_amount"/>
                <field name="rejected_amount"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_insurance_claim_form" model="ir.ui.view">
        <field name="name">pharmacy.insurance.claim.form</field>
        <field name="model">pharmacy.insurance.claim</field>
        <field name="arch" type="xml">
            <form string="Insurance Claim">
                <header>
                    <button name="action_submit" type="object"
                            string="Submit" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" type="object"
                            string="Approve" class="btn-primary"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" type="object"
                            string="Reject"
                            invisible="state != 'submitted'"/>
                    <button name="action_mark_paid" type="object"
                            string="Mark Paid" class="btn-primary"
                            invisible="state not in ('approved', 'partial')"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state not in ('rejected', 'submitted')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="claim_date"/>
                            <field name="provider_id"/>
                            <field name="patient_id"/>
                            <field name="branch_id"/>
                            <field name="pos_order_id"/>
                        </group>
                        <group>
                            <field name="claim_amount"/>
                            <field name="approved_amount"/>
                            <field name="rejected_amount"/>
                            <field name="submission_date"/>
                            <field name="settlement_date"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_insurance_claim_search" model="ir.ui.view">
        <field name="name">pharmacy.insurance.claim.search</field>
        <field name="model">pharmacy.insurance.claim</field>
        <field name="arch" type="xml">
            <search string="Insurance Claims">
                <field name="name"/>
                <field name="provider_id"/>
                <field name="patient_id"/>
                <field name="branch_id"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="pending" string="Pending Settlement"
                        domain="[('state', 'in',
                                 ('submitted', 'approved', 'partial'))]"/>
                <filter name="rejected" string="Rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <filter name="paid" string="Paid"
                        domain="[('state', '=', 'paid')]"/>
                <group name="group_by">
                    <filter name="group_provider" string="Provider"
                            context="{'group_by': 'provider_id'}"/>
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_date" string="Claim Date"
                            context="{'group_by': 'claim_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_insurance_claim" model="ir.actions.act_window">
        <field name="name">Insurance Claims</field>
        <field name="res_model">pharmacy.insurance.claim</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_insurance_claim_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first insurance claim
            </p>
        </field>
    </record>

</odoo>
