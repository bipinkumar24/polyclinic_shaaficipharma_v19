<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_audit_log_list" model="ir.ui.view">
        <field name="name">pharmacy.audit.log.list</field>
        <field name="model">pharmacy.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Trail" create="false" edit="false">
                <field name="log_date"/>
                <field name="user_id"/>
                <field name="action_type"/>
                <field name="name"/>
                <field name="model_name"/>
                <field name="branch_id"/>
                <field name="old_value" optional="hide"/>
                <field name="new_value" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_audit_log_form" model="ir.ui.view">
        <field name="name">pharmacy.audit.log.form</field>
        <field name="model">pharmacy.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Trail Entry" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="log_date"/>
                            <field name="user_id"/>
                            <field name="action_type"/>
                            <field name="branch_id"/>
                        </group>
                        <group>
                            <field name="model_name"/>
                            <field name="res_id"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <group string="Old Value">
                            <field name="old_value" nolabel="1"/>
                        </group>
                        <group string="New Value">
                            <field name="new_value" nolabel="1"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pharmacy_audit_log_search" model="ir.ui.view">
        <field name="name">pharmacy.audit.log.search</field>
        <field name="model">pharmacy.audit.log</field>
        <field name="arch" type="xml">
            <search string="Audit Trail">
                <field name="name"/>
                <field name="user_id"/>
                <field name="model_name"/>
                <field name="branch_id"/>
                <filter name="today" string="Today"
                        domain="[('log_date', '&gt;=',
                                 datetime.datetime.combine(context_today(),
                                 datetime.time(0,0,0)))]"/>
                <separator/>
                <filter name="price_change" string="Price Changes"
                        domain="[('action_type', '=', 'price_change')]"/>
                <filter name="discount" string="Discounts"
                        domain="[('action_type', '=', 'discount')]"/>
                <filter name="refund" string="Refunds / Voids"
                        domain="[('action_type', '=', 'refund')]"/>
                <filter name="pos_override" string="POS Overrides"
                        domain="[('action_type', '=', 'pos_override')]"/>
                <group name="group_by">
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_action" string="Action Type"
                            context="{'group_by': 'action_type'}"/>
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'log_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacy_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Trail</field>
        <field name="res_model">pharmacy.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pharmacy_audit_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No audit entries recorded yet
            </p>
        </field>
    </record>

</odoo>
