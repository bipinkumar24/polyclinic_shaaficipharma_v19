<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_report_category_sales_list" model="ir.ui.view">
        <field name="name">report.pharmacy.category.sales.list</field>
        <field name="model">report.pharmacy.category.sales</field>
        <field name="arch" type="xml">
            <list string="Category Sales" create="false" edit="false">
                <field name="order_date"/>
                <field name="pharmacy_category_id"/>
                <field name="branch_id"/>
                <field name="qty_sold" sum="Qty"/>
                <field name="revenue" sum="Sales Value"/>
                <field name="margin" sum="Margin"/>
                <field name="margin_percent" avg="Avg %" widget="percentage"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_report_category_sales_pivot" model="ir.ui.view">
        <field name="name">report.pharmacy.category.sales.pivot</field>
        <field name="model">report.pharmacy.category.sales</field>
        <field name="arch" type="xml">
            <pivot string="Category Sales Analysis">
                <field name="pharmacy_category_id" type="row"/>
                <field name="order_date" interval="month" type="col"/>
                <field name="revenue" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_category_sales_graph" model="ir.ui.view">
        <field name="name">report.pharmacy.category.sales.graph</field>
        <field name="model">report.pharmacy.category.sales</field>
        <field name="arch" type="xml">
            <graph string="Category Sales Analysis" type="pie">
                <field name="pharmacy_category_id"/>
                <field name="revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_category_sales_search" model="ir.ui.view">
        <field name="name">report.pharmacy.category.sales.search</field>
        <field name="model">report.pharmacy.category.sales</field>
        <field name="arch" type="xml">
            <search string="Category Sales">
                <field name="branch_id"/>
                <filter name="this_month" string="This Month"
                        domain="[('order_date', '&gt;=',
                                 (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group name="group_by">
                    <filter name="group_category" string="Pharmacy Category"
                            context="{'group_by': 'pharmacy_category_id'}"/>
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'order_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_category_sales" model="ir.actions.act_window">
        <field name="name">Category Sales</field>
        <field name="res_model">report.pharmacy.category.sales</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_report_category_sales_search"/>
    </record>

</odoo>
