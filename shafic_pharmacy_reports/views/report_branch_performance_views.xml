<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_report_branch_performance_list" model="ir.ui.view">
        <field name="name">report.pharmacy.branch.performance.list</field>
        <field name="model">report.pharmacy.branch.performance</field>
        <field name="arch" type="xml">
            <list string="Branch Performance" create="false" edit="false">
                <field name="order_date"/>
                <field name="branch_id"/>
                <field name="revenue" sum="Revenue"/>
                <field name="margin" sum="Profitability"/>
                <field name="order_count" sum="Customer Volume"/>
                <field name="avg_basket" avg="Avg Basket"/>
                <field name="qty_sold" sum="Units Sold"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_report_branch_performance_pivot" model="ir.ui.view">
        <field name="name">report.pharmacy.branch.performance.pivot</field>
        <field name="model">report.pharmacy.branch.performance</field>
        <field name="arch" type="xml">
            <pivot string="Branch Performance Analysis">
                <field name="branch_id" type="row"/>
                <field name="order_date" interval="month" type="col"/>
                <field name="revenue" type="measure"/>
                <field name="margin" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_branch_performance_graph" model="ir.ui.view">
        <field name="name">report.pharmacy.branch.performance.graph</field>
        <field name="model">report.pharmacy.branch.performance</field>
        <field name="arch" type="xml">
            <graph string="Branch Performance Analysis" type="bar">
                <field name="branch_id"/>
                <field name="revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_branch_performance_search" model="ir.ui.view">
        <field name="name">report.pharmacy.branch.performance.search</field>
        <field name="model">report.pharmacy.branch.performance</field>
        <field name="arch" type="xml">
            <search string="Branch Performance">
                <field name="branch_id"/>
                <filter name="this_month" string="This Month"
                        domain="[('order_date', '&gt;=',
                                 (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group name="group_by">
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'order_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_branch_performance"
            model="ir.actions.act_window">
        <field name="name">Branch Performance</field>
        <field name="res_model">report.pharmacy.branch.performance</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id"
               ref="view_report_branch_performance_search"/>
    </record>

</odoo>
