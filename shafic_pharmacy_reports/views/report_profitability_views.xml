<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_report_profitability_list" model="ir.ui.view">
        <field name="name">report.pharmacy.profitability.list</field>
        <field name="model">report.pharmacy.profitability</field>
        <field name="arch" type="xml">
            <list string="Profitability Analysis" create="false"
                  edit="false">
                <field name="order_date"/>
                <field name="product_id"/>
                <field name="categ_id" optional="hide"/>
                <field name="pharmacy_category_id"/>
                <field name="branch_id"/>
                <field name="qty" sum="Quantity"/>
                <field name="revenue" sum="Revenue"/>
                <field name="cost" sum="Cost" optional="hide"/>
                <field name="margin_value" sum="Margin Value"/>
                <field name="margin_percent" avg="Avg Margin %"
                       widget="percentage"/>
                <field name="discount_amount" sum="Discount" optional="hide"/>
                <field name="discount_percent" avg="Avg Discount %"
                       widget="percentage" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_report_profitability_pivot" model="ir.ui.view">
        <field name="name">report.pharmacy.profitability.pivot</field>
        <field name="model">report.pharmacy.profitability</field>
        <field name="arch" type="xml">
            <pivot string="Profitability Analysis">
                <field name="pharmacy_category_id" type="row"/>
                <field name="order_date" interval="month" type="col"/>
                <field name="margin_value" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_profitability_graph" model="ir.ui.view">
        <field name="name">report.pharmacy.profitability.graph</field>
        <field name="model">report.pharmacy.profitability</field>
        <field name="arch" type="xml">
            <graph string="Profitability Analysis" type="bar">
                <field name="pharmacy_category_id"/>
                <field name="margin_value" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_report_profitability_search" model="ir.ui.view">
        <field name="name">report.pharmacy.profitability.search</field>
        <field name="model">report.pharmacy.profitability</field>
        <field name="arch" type="xml">
            <search string="Profitability Analysis">
                <field name="product_id"/>
                <field name="categ_id"/>
                <field name="branch_id"/>
                <filter name="today" string="Today"
                        domain="[('order_date', '&gt;=',
                                 (context_today().strftime('%Y-%m-%d 00:00:00')))]"/>
                <filter name="this_week" string="This Week"
                        domain="[('order_date', '&gt;=',
                                 ((context_today() + relativedelta(weeks=-1))
                                  .strftime('%Y-%m-%d 00:00:00')))]"/>
                <filter name="this_month" string="This Month"
                        domain="[('order_date', '&gt;=',
                                 (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="discounted" string="Discounted Lines"
                        domain="[('discount_amount', '&gt;', 0)]"/>
                <group name="group_by">
                    <filter name="group_category" string="Pharmacy Category"
                            context="{'group_by': 'pharmacy_category_id'}"/>
                    <filter name="group_product" string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_branch" string="Branch"
                            context="{'group_by': 'branch_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'order_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_profitability" model="ir.actions.act_window">
        <field name="name">Profitability Analysis</field>
        <field name="res_model">report.pharmacy.profitability</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id"
               ref="view_report_profitability_search"/>
        <field name="context">{'search_default_this_month': 1,
                               'search_default_group_product': 1}</field>
    </record>

</odoo>
