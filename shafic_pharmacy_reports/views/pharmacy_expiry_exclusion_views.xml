<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_expiry_exclusion_list" model="ir.ui.view">
        <field name="name">pharmacy.expiry.exclusion.list</field>
        <field name="model">pharmacy.expiry.exclusion</field>
        <field name="arch" type="xml">
            <list string="Expiry Exclusions"
                  decoration-success="state == 'approved'"
                  decoration-muted="state == 'rejected'"
                  decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="expiry_date"/>
                <field name="product_id"/>
                <field name="lot_id" optional="hide"/>
                <field name="quantity" optional="hide"/>
                <field name="excluded_value" sum="Excluded"/>
                <field name="reason"/>
                <field name="requested_by" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'rejected'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_expiry_exclusion_form" model="ir.ui.view">
        <field name="name">pharmacy.expiry.exclusion.form</field>
        <field name="model">pharmacy.expiry.exclusion</field>
        <field name="arch" type="xml">
            <form string="Expiry Exclusion">
                <header>
                    <button name="action_approve" type="object"
                            string="Approve" class="oe_highlight"
                            invisible="state != 'draft'"
                            groups="shafic_pharmacy_reports.group_pharmacy_admin"/>
                    <button name="action_reject" type="object"
                            string="Reject"
                            invisible="state != 'draft'"
                            groups="shafic_pharmacy_reports.group_pharmacy_admin"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft"
                            invisible="state == 'draft'"
                            groups="shafic_pharmacy_reports.group_pharmacy_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Loss">
                            <field name="expiry_date"
                                   readonly="state != 'draft'"/>
                            <field name="product_id"
                                   readonly="state != 'draft'"/>
                            <field name="lot_id"
                                   readonly="state != 'draft'"/>
                            <field name="quantity"
                                   readonly="state != 'draft'"/>
                            <field name="excluded_value"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Justification">
                            <field name="reason"
                                   readonly="state != 'draft'"/>
                            <field name="requested_by"/>
                            <field name="approved_by"/>
                            <field name="approved_on"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1"
                               readonly="state != 'draft'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pharmacy_expiry_exclusion_search" model="ir.ui.view">
        <field name="name">pharmacy.expiry.exclusion.search</field>
        <field name="model">pharmacy.expiry.exclusion</field>
        <field name="arch" type="xml">
            <search string="Expiry Exclusions">
                <field name="name"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="approved" string="Approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter name="rejected" string="Rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter name="this_year" string="This Year"
                        domain="[('year', '=', context_today().year)]"/>
                <group name="group_by">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_reason" string="Reason"
                            context="{'group_by': 'reason'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'expiry_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pharmacy_expiry_exclusion"
            model="ir.actions.act_window">
        <field name="name">Expiry Exclusions</field>
        <field name="res_model">pharmacy.expiry.exclusion</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id"
               ref="view_pharmacy_expiry_exclusion_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log an uncontrollable expiry loss
            </p>
            <p>
                Use this to record expiry losses that should not count
                against the inventory team's bonus rate — typically
                equipment failures, short-dated supplier deliveries, or
                regulatory recalls. Each entry must be approved by a
                Pharmacy Admin before it is deducted from the bonus
                calculation.
            </p>
        </field>
    </record>

</odoo>
