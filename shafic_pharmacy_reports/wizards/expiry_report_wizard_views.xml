<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_expiry_report_wizard_form" model="ir.ui.view">
        <field name="name">pharmacy.expiry.report.wizard.form</field>
        <field name="model">pharmacy.expiry.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Expiry Report">
                <sheet>
                    <group>
                        <field name="expiry_bucket"/>
                        <field name="pharmacy_category_id"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_view_report" type="object"
                            string="View Report" class="btn-primary"/>
                    <button name="action_print_pdf" type="object"
                            string="Print PDF" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_expiry_report_wizard" model="ir.actions.act_window">
        <field name="name">Expiry Report</field>
        <field name="res_model">pharmacy.expiry.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
