<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="sh_warehouse_cost_tree_view" model="ir.ui.view">
            <field name="name">sh.warehouse.cost.list</field>
            <field name="model">sh.warehouse.cost</field>
            <field name="arch" type="xml">
                <list string="Warehouse Wise Stock" create="false" edit="false" delete="false">
                    <field name="warehouse_id"/>
                    <field name="product_id"/>
                    <field name="company_id"/>
                    <field name="sh_onhand_qty" sum="Total On Hand Quantity"/>
                    <field name="cost" sum="Total Cost"/>
                </list>
            </field>
        </record>


        <record id="sh_warehouse_cost_search_view" model="ir.ui.view">
            <field name="name">sh.warehouse.cost.search</field>
            <field name="model">sh.warehouse.cost</field>
            <field name="arch" type="xml">
                <search string="Search Warehouse Wise Stock">
                    <field name="warehouse_id"/>
                    <field name="product_id"/>
                    <group>
                        <filter string="Warehouse" name="group_by_warehouse" context="{'group_by':'warehouse_id'}"/>
                        <filter string="Product" name="group_by_product" context="{'group_by':'product_id'}"/>
                    </group>
                </search>
            </field>
        </record>




        <record id="action_sh_warehouse_wise_stock" model="ir.actions.act_window">
            <field name="name">Warehouse wise Stock</field>
            <field name="res_model">sh.warehouse.cost</field>
            <field name="view_mode">list</field>
            <field name="context">
            {'search_default_group_by_warehouse': 1,
            'search_default_group_by_product': 1}
            </field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
            No warehouse wise stock found.
                </p>
            </field>
        </record>





        <menuitem id="menu_sh_warehouse_wise_stock" name="Warehouse wise Stock" parent="stock.menu_warehouse_report" action="action_sh_warehouse_wise_stock" sequence="10"/>

    </data>
</odoo>
