<odoo>
    <record id="view_import_inventory_adjustment_wizard" model="ir.ui.view">
        <field name="model">import.inventory.adjustment.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Inventory Adjustment">
                <group>
                    <field name="location_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="file" filename="filename"/>
                    <field name="result_filename"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_import_inventory_adjustment" model="ir.actions.act_window">
        <field name="res_model">import.inventory.adjustment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>