<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_shafic_pulse" model="ir.module.category">
        <field name="name">Shafic Pulse</field>
        <field name="sequence">90</field>
    </record>

    <!-- v19: res.groups lost category_id; categories now live on
         res.groups.privilege, which the group points to via privilege_id.
         Pattern mirrored from addons/account/security/account_security.xml. -->
    <record id="privilege_shafic_pulse" model="res.groups.privilege">
        <field name="name">Shafic Pulse</field>
        <field name="category_id" ref="module_category_shafic_pulse"/>
        <field name="sequence">90</field>
    </record>

    <record id="group_pulse_viewer" model="res.groups">
        <field name="name">Pulse Viewer</field>
        <field name="privilege_id" ref="privilege_shafic_pulse"/>
        <field name="comment">Can open the CEO Pulse dashboard.</field>
    </record>

    <!-- Settings administrators get the dashboard by default. -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_pulse_viewer'))]"/>
    </record>
</odoo>
